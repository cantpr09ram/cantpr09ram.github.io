---
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import ThemeToggle from "../components/ThemeToggle.astro";

interface Props {
	bodyClass?: string;
	shellClass?: string;
	mainClass?: string;
	showHeader?: boolean;
	showFooter?: boolean;
}

const {
	bodyClass = "antialiased tracking-tight font-sans",
	shellClass = "min-h-screen flex flex-col pt-10 md:pt-8 p-8 bg-[var(--app-bg)] text-[var(--app-text)]",
	mainClass = "max-w-[var(--layout-main-max)] mx-auto w-full flex flex-col flex-1",
	showHeader = false,
	showFooter = false,
} = Astro.props;
---

<body class={bodyClass}>
	<ThemeToggle />
	<div class={shellClass}>
		<main class={mainClass}>
			{showHeader && <Header />}
			<slot />
			{showFooter && <Footer />}
		</main>
	</div>
</body>
