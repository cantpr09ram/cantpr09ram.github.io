---
import BaseHead from "../components/BaseHead.astro";
import EarthGlobe from "../components/EarthGlobe.astro";
import ThemeToggle from "../components/ThemeToggle.astro";

const markers = [
	{ id: "taipei", label: "Taipei", location: [25.033, 121.5654], size: 0.03 },
	//{ id: "nyc", label: "New York", location: [40.7128, -74.006], size: 0.03 },
	//{ id: "london", label: "London", location: [51.5072, -0.1276], size: 0.03 },
];

const globeConfig = {
	rotationSpeed: 0.001,
	mapBrightness: 8,
};
---
<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="404" description="Page not found" />
	</head>
	<body class="antialiased max-w-[var(--layout-main-max)] mx-4 mt-8 lg:mx-auto bg-[var(--app-bg)] text-[var(--app-text)]">
		<ThemeToggle />
		<main class="flex-auto min-w-0 mt-6 flex flex-col px-2 md:px-0">
			<section class="mx-auto flex min-h-[84vh] w-full max-w-3xl flex-col items-center justify-center text-center">
				<EarthGlobe
					markers={markers}
					rotationSpeed={globeConfig.rotationSpeed}
					mapBrightness={globeConfig.mapBrightness}
				/>
			</section>
		</main>
	</body>
</html>
